# =============================================================================
# CardSync Frontend — environment template (copy to .env and fill values)
# =============================================================================

# Backend API base URL (required for Amplify / staging / production builds).
# Local Vite DEV may use a local API URL; the Vite proxy handles same-origin calls.
VITE_API_URL=http://127.0.0.1:5000

# Optional: contact storage mode
# VITE_CONTACT_STORAGE=indexeddb
